{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/validate-i18n-after-edit.sh\"",
            "timeout": 15000
          }
        ]
      }
    ]
  }
}
