{
  "name": "safe-i18n",
  "version": "0.1.0",
  "description": "AI-assisted i18n migration CLI for React/Next.js that helps coding agents add localization safely",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "safe-i18n": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "AGENTS.md",
    "llms.txt",
    "docs/agent-usage.md",
    "docs/architecture.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "i18n",
    "internationalization",
    "react",
    "nextjs",
    "next-intl",
    "migration",
    "codemod",
    "ast",
    "translation",
    "cli",
    "safe",
    "ai-assisted",
    "llm",
    "ai",
    "ai-agent",
    "coding-agent",
    "developer-tools",
    "static-analysis",
    "localization-tools"
  ],
  "author": "semih702",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Semih702/safe-i18n.git"
  },
  "homepage": "https://github.com/Semih702/safe-i18n#readme",
  "bugs": {
    "url": "https://github.com/Semih702/safe-i18n/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@babel/generator": "^7.27.0",
    "@babel/parser": "^7.27.0",
    "@babel/traverse": "^7.27.0",
    "@babel/types": "^7.27.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "fast-glob": "^3.3.3",
    "ora": "^8.2.0",
    "recast": "^0.23.9",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/babel__generator": "^7.6.8",
    "@types/babel__traverse": "^7.20.6",
    "@types/node": "^22.10.0",
    "eslint": "^9.16.0",
    "prettier": "^3.4.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0",
    "vitest": "^3.0.0"
  }
}
